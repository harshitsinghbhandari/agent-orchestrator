{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist-server",
    "rootDir": ".",
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "verbatimModuleSyntax": false
  },
  "include": [
    "server",
    "src/lib/voice-dedupe.ts",
    "src/lib/voice-token.ts",
    "src/lib/voice-functions.ts",
    "src/lib/voice-serialize.ts",
    "src/lib/pending-merges.ts",
    "src/lib/types.ts",
    "src/lib/global-pause.ts"
  ],
  "exclude": ["server/__tests__"]
}
